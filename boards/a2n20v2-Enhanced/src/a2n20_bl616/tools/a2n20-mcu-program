#!/usr/bin/env python3
"""A2N20 BL616 Firmware Programmer

Programs the BL616 microcontroller on the Tang Nano 20K board with
A2N20 firmware. Pre-detects board state (fused/unfused/bricked) and
chooses the optimal flash strategy automatically.

Default behavior:
  1. Detect what's currently running on the board
  2. Choose flash strategy based on board state
  3. Enter boot mode and flash
  4. Verify firmware is running

Manual overrides:
  --stage1 [PATH]   Force flash image at 0x0
  --stage2 [PATH]   Force flash image at 0x40000
  --stage1 + --stage2  Flash both addresses

Dependencies:
  pip install bflb-iot-tool   (also installs pyserial)
"""

import argparse
import glob
import os
import re
import shutil
import subprocess
import sys
import tempfile
import time

from serial.tools import list_ports

# Flash addresses
ADDR_STAGE1 = "0x0"
ADDR_STAGE2 = "0x40000"

# Default baudrate. 500000 is reliable across the cables/ports we've tested;
# 2000000 frequently fails mid-write ("BFLB FLASH WRITE FAIL"). flash_image()
# auto-falls-back to slower rates on failure, so this is just the start point.
DEFAULT_BAUDRATE = 500000

# Bouffalo VID/PID — ROM bootloader / CDC DEMO (secure boot failure)
BOUFFALO_VID = 0x349B
BOUFFALO_PID = 0x6160

# FTDI VID/PID — FT2232-compatible firmware
FTDI_VID = 0x0403
FTDI_PID = 0x6010

# Known product strings for board identification
PRODUCT_SIPEED_STOCK = "USB Debugger"
PRODUCT_FRIEND_20K = "20K's FRIEND"
PRODUCT_A2N20 = "JTAG Debugger"

# Board states
STATE_SIPEED_STOCK = "sipeed_stock"   # Fused board, Sipeed signed Stage 1
STATE_FRIEND_20K = "friend_20k"       # Unfused board, friend_20k firmware
STATE_A2N20 = "a2n20"                 # Already running our firmware
STATE_CDC_DEMO = "cdc_demo"           # Bricked / secure boot failure
STATE_UNKNOWN_FTDI = "unknown_ftdi"   # Unknown FT2232 device
STATE_NOT_FOUND = "not_found"         # No relevant device

# Boot mode retry limit
BOOT_MODE_RETRIES = 3

# Recovery image filenames
FRIEND_20K_BIN = "friend_20k_bl616.bin"
SIPEED_STOCK_BIN = "bl616_fpga_partner_20kNano.bin"


# --- ANSI color support ---

def _use_color():
    if os.environ.get("NO_COLOR"):
        return False
    return sys.stdout.isatty()

USE_COLOR = _use_color()

def _color(code, text):
    if USE_COLOR:
        return f"\033[{code}m{text}\033[0m"
    return text

def green(text):
    return _color("32", text)

def red(text):
    return _color("31", text)

def yellow(text):
    return _color("33", text)

def bold(text):
    return _color("1", text)


# --- Path resolution ---

def script_dir():
    return os.path.dirname(os.path.abspath(__file__))

def project_root():
    return os.path.dirname(script_dir())

def default_firmware_path():
    return os.path.join(project_root(), "firmware", "build", "build_out",
                        "a2n20_bl616_bl616.bin")

def recovery_path(name):
    return os.path.join(project_root(), "recovery", name)


# --- User interaction ---

# Set from --non-interactive. When True the tool never blocks on input and
# assumes the board is already in the required state (e.g. boot mode); intended
# for scripts and coding agents driving the flash.
NON_INTERACTIVE = False

# Set from --verify-flash. When True, flash_image() reads the region back after
# a successful write and byte-compares it to the source image.
VERIFY_FLASH = False

def prompt(msg="Press Enter when ready..."):
    """Prompt the user, handling non-interactive (piped/agent) use gracefully."""
    if NON_INTERACTIVE:
        print(msg + yellow("  [--non-interactive: continuing]"))
        return
    try:
        input(msg)
    except EOFError:
        print()


# --- Dependency checks ---

def check_bflb_iot_tool():
    if shutil.which("bflb-iot-tool") is None:
        print(red("ERROR:") + " bflb-iot-tool is not installed.")
        print()
        print("Install it with:")
        print("  pip install bflb-iot-tool")
        print()
        sys.exit(1)


# --- USB device detection ---

def find_ports(vid=None, pid=None):
    """Find serial ports matching the given VID and optional PID."""
    ports = []
    for p in list_ports.comports():
        if p.vid == vid:
            if pid is None or p.pid == pid:
                ports.append(p)
    return ports


def detect_board_state():
    """Detect what's currently running on the Tang Nano 20K.

    Returns (state, ports) where state is one of the STATE_* constants
    and ports is the list of matching port info objects.
    """
    # Check for FT2232-compatible devices (VID 0x0403, PID 0x6010)
    ftdi_ports = find_ports(vid=FTDI_VID, pid=FTDI_PID)
    for p in ftdi_ports:
        desc = p.description or ""
        if PRODUCT_A2N20 in desc:
            return STATE_A2N20, ftdi_ports
        if PRODUCT_SIPEED_STOCK in desc:
            return STATE_SIPEED_STOCK, ftdi_ports
        if PRODUCT_FRIEND_20K in desc:
            return STATE_FRIEND_20K, ftdi_ports

    # If we found FTDI ports but didn't recognize the product string
    if ftdi_ports:
        return STATE_UNKNOWN_FTDI, ftdi_ports

    # Check for Bouffalo CDC DEMO (bricked / secure boot failure)
    cdc_ports = find_ports(vid=BOUFFALO_VID)
    if cdc_ports:
        return STATE_CDC_DEMO, cdc_ports

    return STATE_NOT_FOUND, []


def detect_boot_port():
    """Auto-detect BL616 serial port in boot mode (Bouffalo CDC)."""
    ports = find_ports(vid=BOUFFALO_VID)
    if not ports:
        return None
    if len(ports) == 1:
        return ports[0].device

    print(yellow("WARNING:") + " Multiple Bouffalo CDC devices detected:")
    for p in ports:
        print(f"  {p.device}  ({p.description})")
    print()
    print("Please specify the correct port with --port")
    sys.exit(1)


def read_boot_info(port_dev):
    """Read the BootROM's boot_info over the ISP serial protocol.

    Only works while the board is in boot mode (Bouffalo CDC device).
    Returns dict(raw=<hex str>, sign=<int>, encrypt=<int>) or None.

    boot_info bytes 4/5 are the eFuse security state (bflb parse for
    bl616): sign != 0 -> secure boot enforced; encrypt != 0 -> flash
    image at 0x0 must be AES-encrypted with the key burned in eFuse.
    Both zero -> UNFUSED. This is THE discriminator for which Stage 1
    image a board can boot:
      fused   -> Sipeed's bl616_fpga_partner_20kNano.bin (AES-encrypted)
      unfused -> friend_20k_bl616.bin (plaintext; the BootROM of an
                 unfused board REJECTS the encrypted partner image)
    """
    import serial as pyserial
    import binascii
    try:
        sp = pyserial.Serial(port_dev, 500000, timeout=2)
    except Exception:
        return None
    try:
        for _ in range(2):
            sp.reset_input_buffer()
            sp.write(b"\x55" * 300)
            time.sleep(0.2)
            if sp.read(2) == b"OK":
                break
        else:
            return None
        sp.reset_input_buffer()
        sp.write(bytes([0x10, 0x00, 0x00, 0x00]))
        time.sleep(0.2)
        if sp.read(2) != b"OK":
            return None
        ln = int.from_bytes(sp.read(2), "little")
        payload = sp.read(ln)
        if len(payload) < 6:
            return None
        return {
            "raw": binascii.hexlify(payload).decode(),
            "sign": payload[4],
            "encrypt": payload[5],
        }
    except Exception:
        return None
    finally:
        try:
            sp.close()
        except Exception:
            pass


def describe_efuse_state(info):
    """One-line human classification of read_boot_info() output."""
    if info is None:
        return yellow("eFuse state: (could not read boot_info)")
    if info["sign"] == 0 and info["encrypt"] == 0:
        return (green("eFuse state: UNFUSED") +
                f" (sign=0, encrypt=0)  boot_info={info['raw']}")
    enc = {1: "AES-128", 2: "AES-256", 3: "AES-192"}.get(
        info["encrypt"], f"type {info['encrypt']}")
    return (green("eFuse state: FUSED") +
            f" (sign={info['sign']}, encrypt={info['encrypt']}: {enc})"
            f"  boot_info={info['raw']}")


def recovery_dir():
    """recovery/ directory holding the Stage 1 images, relative to this
    script (tools/ -> ../recovery)."""
    return os.path.join(os.path.dirname(os.path.abspath(__file__)),
                        os.pardir, "recovery")


def pick_stage1_image(info):
    """Choose the correct Stage 1 recovery image for the board's eFuse
    state. Returns (path, reason) or (None, reason)."""
    if info is None:
        return None, ("cannot choose a Stage 1 image: boot_info read "
                      "failed (need the board in boot mode)")
    if info["encrypt"] != 0 or info["sign"] != 0:
        return (os.path.join(recovery_dir(),
                             "bl616_fpga_partner_20kNano.bin"),
                "fused board -> Sipeed partner Stage 1 (AES-encrypted "
                "factory image; also UPGRADES old Stage 1s that lack "
                "0x40000 chain-load support)")
    return (os.path.join(recovery_dir(), "friend_20k_bl616.bin"),
            "unfused board -> friend_20k Stage 1 (plaintext; the "
            "encrypted partner image CANNOT boot on unfused silicon)")


def wait_for_board_state(target_states, timeout_secs=10):
    """Wait for the board to show a specific state after power cycle.

    Returns (state, ports) or (STATE_NOT_FOUND, []) on timeout.
    """
    deadline = time.time() + timeout_secs
    while time.time() < deadline:
        state, ports = detect_board_state()
        if state in target_states:
            return state, ports
        time.sleep(0.5)
    return STATE_NOT_FOUND, []


def print_board_info(state, ports):
    """Print details about the detected board state."""
    if state == STATE_SIPEED_STOCK:
        print(green("  [DETECTED]") + " Sipeed stock firmware (fused board)")
        for p in ports:
            print(f"    {p.description}: {p.device}  [serial: {p.serial_number}]")
    elif state == STATE_FRIEND_20K:
        print(green("  [DETECTED]") + " friend_20k firmware (unfused board)")
        for p in ports:
            print(f"    {p.description}: {p.device}  [serial: {p.serial_number}]")
    elif state == STATE_A2N20:
        print(green("  [DETECTED]") + " A2N20 firmware (already installed)")
        for p in ports:
            print(f"    {p.description}: {p.device}  [serial: {p.serial_number}]")
    elif state == STATE_CDC_DEMO:
        print(yellow("  [DETECTED]") + " Bouffalo BootROM (boot/recovery mode)")
        for p in ports:
            print(f"    {p.device}")
        print("    This means one of: UPDATE was held at power-on (boot mode),")
        print("    nothing is flashed at 0x0, or the BootROM REJECTED the")
        print("    Stage 1 image at 0x0 (e.g. the AES-encrypted Sipeed partner")
        print("    image on an UNFUSED board, which cannot decrypt it).")
        info = read_boot_info(ports[0].device)
        print("    " + describe_efuse_state(info))
        s1, why = pick_stage1_image(info)
        if s1:
            print(f"    Correct Stage 1 for this board: {os.path.basename(s1)}")
            print(f"      ({why})")
        print("    Include the eFuse/boot_info line above in any field report.")
    elif state == STATE_UNKNOWN_FTDI:
        print(yellow("  [DETECTED]") + " Unknown FT2232 device")
        for p in ports:
            desc = p.description or p.device
            print(f"    {desc}: {p.device}")
    else:
        print(yellow("  [NOT FOUND]") + " No Tang Nano 20K detected")


# --- Boot mode entry ---

def wait_for_boot_port(specified_port=None):
    """Wait for BL616 to appear in boot mode, with retries."""
    for attempt in range(BOOT_MODE_RETRIES):
        if specified_port:
            if os.path.exists(specified_port):
                return specified_port
            else:
                print(red("ERROR:") + f" Specified port {specified_port} not found.")
                if attempt < BOOT_MODE_RETRIES - 1:
                    print("Make sure the board is in boot mode and try again.")
                    prompt("\nPress Enter to retry...")
                continue
        else:
            port = detect_boot_port()
            if port:
                return port

            if attempt < BOOT_MODE_RETRIES - 1:
                print(yellow("No BL616 device detected in boot mode."))
                print()
                print("To enter boot mode:")
                print("  1. Disconnect the Tang Nano 20K from USB")
                print("  2. Press and hold the UPDATE button (top of board, behind HDMI)")
                print("  3. While holding UPDATE, connect USB-C to the Debug port")
                print("  4. Release the UPDATE button")
                prompt("\nPress Enter when ready...")
                print()
                print("Detecting BL616 in boot mode...", end=" ", flush=True)
                time.sleep(1)

    print(red("ERROR:") + " Could not detect BL616 in boot mode after "
          f"{BOOT_MODE_RETRIES} attempts.")
    print()
    print("Troubleshooting:")
    print("  - Make sure you're using the Debug USB-C port (not HDMI)")
    print("  - Hold UPDATE before connecting USB, release after")
    print("  - Try a different USB cable")
    if not specified_port:
        print("  - Specify the port manually with --port /dev/tty.usbmodemXXXX")
    sys.exit(1)


# --- Flash operations ---

def _bflb_flash_once(port, image_path, address, baudrate, verbose):
    """Run bflb-iot-tool once. Returns (ok, combined_output_text).

    bflb-iot-tool frequently exits 0 even when the write failed, so success
    requires BOTH a zero exit code AND no 'fail'/'error' in its output.
    """
    cmd = [
        "bflb-iot-tool",
        "--chipname", "bl616",
        "--interface", "uart",
        "--port", port,
        "--baudrate", str(baudrate),
        "--firmware", image_path,
        "--addr", address,
        "--single",
    ]

    if verbose:
        print(f"  Command: {' '.join(cmd)}")
        print()

    try:
        result = subprocess.run(
            cmd,
            capture_output=not verbose,
            text=True,
            timeout=120,
        )
    except subprocess.TimeoutExpired:
        return False, "flash command timed out after 120 seconds"
    except FileNotFoundError:
        print(red("  [ERROR]") + " bflb-iot-tool not found in PATH")
        sys.exit(1)

    output = (result.stdout or "") + (result.stderr or "")
    ok = (result.returncode == 0
          and "fail" not in output.lower()
          and "error" not in output.lower())
    return ok, output


def flash_image(port, image_path, address, baudrate, label, verbose=False):
    """Flash a binary image to the BL616, auto-retrying at slower baud rates.

    On total failure this EXITS the process (non-zero) — so if it returns, the
    flash genuinely succeeded and callers need not check the return value.
    """
    if not os.path.isfile(image_path):
        print(red("ERROR:") + f" {label} not found: {image_path}")
        sys.exit(1)

    size_kb = os.path.getsize(image_path) / 1024
    print(f"  Image: {os.path.basename(image_path)} ({size_kb:.0f} KB)")
    print(f"  Address: {address}")
    print(f"  Port: {port}")

    # Start at the requested baud, then fall back to progressively slower,
    # more reliable rates if the write fails.
    bauds = [baudrate]
    for b in (500000, 115200):
        if b < baudrate and b not in bauds:
            bauds.append(b)

    last_output = ""
    for i, baud in enumerate(bauds):
        if i > 0:
            print(yellow(f"  write failed — retrying at {baud} baud..."))
        ok, last_output = _bflb_flash_once(port, image_path, address, baud, verbose)
        if ok:
            print(green("  [OK]") + f" {label} flashed successfully (baud {baud})")
            if VERIFY_FLASH and not verify_flash_image(port, image_path, address, baud, verbose):
                # Read-back mismatch is a hard error.
                sys.exit(1)
            return True

    # Every baud rate failed — this is a hard error.
    print(red("  [ERROR]") + f" {label} flash failed after trying baud rate(s): "
          + ", ".join(str(b) for b in bauds))
    if not verbose and last_output.strip():
        print()
        print("  bflb-iot-tool output (last attempt):")
        for line in last_output.strip().splitlines():
            print(f"    {line}")
    print()
    print("  Suggestions:")
    print("  - Make sure the board is still in boot mode (re-enter with UPDATE)")
    print("  - Try a different USB cable / port")
    print("  - Run with --verbose to see full tool output")
    sys.exit(1)


def _bflb_iot_tool_dir():
    """Return the bflb_iot_tool package directory, where its --read writes
    'flash.bin'. Resolved via the interpreter behind the bflb-iot-tool CLI."""
    exe = shutil.which("bflb-iot-tool")
    py = sys.executable
    if exe:
        try:
            with open(exe) as f:
                first = f.readline()
            if first.startswith("#!"):
                py = first[2:].strip().split()[0]
        except Exception:
            pass
    try:
        out = subprocess.run(
            [py, "-c", "import bflb_iot_tool,os;print(os.path.dirname(bflb_iot_tool.__file__))"],
            capture_output=True, text=True, timeout=15)
        path = out.stdout.strip()
        return path or None
    except Exception:
        return None


def verify_flash_image(port, image_path, address, baudrate, verbose=False):
    """Read the flashed region back from the chip and byte-compare it to the
    source image.

    Returns True on an exact match. Returns False ONLY on a confirmed byte
    mismatch (real corruption). If the read-back itself can't be completed
    (tool/port error, output file not found), prints a warning and returns True
    — we don't fail an otherwise-successful flash because the verify plumbing
    misbehaved; the caller already confirmed the write succeeded.
    """
    print(bold("  Verifying flash (read-back compare)..."))

    # Callers pass the address either as an int or as a string like "0x40000".
    if isinstance(address, str):
        address = int(address, 0)

    with open(image_path, "rb") as fp:
        src = fp.read()
    n = len(src)
    # bflb-iot-tool --read uses an INCLUSIVE end address.
    start_hex = f"{address:x}"
    end_hex = f"{address + n - 1:x}"

    with tempfile.TemporaryDirectory() as tmpdir:
        cmd = [
            "bflb-iot-tool",
            "--chipname", "bl616",
            "--interface", "uart",
            "--port", port,
            "--baudrate", str(baudrate),
            "--read",
            "--start", start_hex,
            "--end", end_hex,
            "--outdir", tmpdir,
        ]
        if verbose:
            print(f"  Command: {' '.join(cmd)}")
        # bflb-iot-tool writes the read-back to 'flash.bin' in its own package
        # dir (not cwd/outdir). Use mtime to distinguish a fresh read from any
        # stale flash.bin left by a previous run.
        start = time.time() - 2  # small clock-skew margin
        try:
            result = subprocess.run(cmd, cwd=tmpdir, capture_output=not verbose,
                                    text=True, timeout=120)
        except (subprocess.TimeoutExpired, FileNotFoundError) as e:
            print(yellow("  [WARN]") + f" read-back could not run ({e}); "
                  "skipping verify (flash itself succeeded).")
            return True

        # Search likely locations for a freshly-written flash.bin.
        search = [os.path.join(tmpdir, "flash.bin"), os.path.join(os.getcwd(), "flash.bin")]
        pkg = _bflb_iot_tool_dir()
        if pkg:
            search.append(os.path.join(pkg, "flash.bin"))
        search += glob.glob(os.path.join(tmpdir, "**", "flash.bin"), recursive=True)

        read_path = next((p for p in search
                          if os.path.isfile(p) and os.path.getmtime(p) >= start), None)
        if read_path is None:
            print(yellow("  [WARN]") + " read-back file not found; skipping "
                  "verify (flash itself succeeded). Re-run with --verbose to see "
                  "the read output.")
            if not verbose and result.stdout:
                for line in result.stdout.strip().splitlines()[-5:]:
                    print(f"    {line}")
            return True

        with open(read_path, "rb") as fp:
            back = fp.read()

    # The read-back may be padded up to a sector boundary; compare the first n.
    if len(back) < n:
        print(yellow("  [WARN]") + f" read-back short ({len(back)} < {n} bytes); "
              "skipping verify.")
        return True

    if back[:n] == src:
        print(green("  [OK]") + f" verified {n} bytes at 0x{address:x} match the image")
        return True

    # Confirmed mismatch — report the first differing offset.
    first_diff = next((i for i in range(n) if back[i] != src[i]), None)
    print(red("  [ERROR]") + f" read-back MISMATCH at 0x{address:x} "
          f"(first differing byte at offset {first_diff})")
    print("  The flash does not match the image. Re-enter boot mode and reflash.")
    return False


# --- CLI probe (identify running firmware) ---

# Break-in sequence shared by the A2N20 firmware CLI: Ctrl-X, Ctrl-C, Enter.
CLI_BREAKIN = bytes([0x18, 0x03, 0x0D])

# Strip ANSI color/escape sequences (the stock firmware colorizes its prompt).
ANSI_RE = re.compile(r"\x1b\[[0-9;]*[A-Za-z]")


def _is_mpsse_noise(raw):
    """An FT2232 JTAG/MPSSE channel answers stray bytes with 0xFA ('bad
    command') + the offending byte. Detect that so we don't mistake it for a
    CLI talking back."""
    if not raw:
        return False
    fa = raw.count(0xFA)
    printable = sum(1 for b in raw if (32 <= b < 127) or b in (9, 10, 13))
    return fa >= 2 and printable < len(raw) * 0.5


def probe_cli_port(port, verbose=False):
    """Send the Ctrl-X Ctrl-C Enter break-in (then 'help' if it looks like a
    real CLI) and return (raw_bytes, error)."""
    try:
        import serial  # pyserial (already a dependency: list_ports)
    except ImportError:
        return None, "pyserial not installed (pip install pyserial)"

    try:
        ser = serial.Serial(port, 115200, timeout=0.4)
    except Exception as e:  # noqa: BLE001
        return None, f"could not open {port}: {e}"

    try:
        ser.reset_input_buffer()
        # Send the three bytes as separate keystrokes (some break-in state
        # machines step per byte).
        for b in CLI_BREAKIN:
            ser.write(bytes([b]))
            ser.flush()
            time.sleep(0.05)
        time.sleep(0.4)
        data = ser.read(4096)
        # Only ask for 'help' if this wasn't a JTAG/MPSSE channel — otherwise we
        # just get 0xFA noise back.
        if not _is_mpsse_noise(data):
            ser.write(b"help\r")
            ser.flush()
            time.sleep(0.6)
            data += ser.read(8192)
    except Exception as e:  # noqa: BLE001
        return None, f"I/O error on {port}: {e}"
    finally:
        try:
            ser.close()
        except Exception:
            pass

    return data, None


def identify_cli(raw):
    """Classify a raw probe response. Returns (label, kind) where kind is one of
    'a2n20', 'other', 'jtag', 'none'."""
    if not raw:
        return "no CLI response", "none"
    if _is_mpsse_noise(raw):
        return "JTAG/MPSSE channel (not a CLI)", "jtag"
    text = raw.decode("latin-1", "replace")
    if not text.strip():
        return "no CLI response", "none"
    low = text.lower()
    if "a2n20>" in low or "a2n20 bl616 firmware" in low:
        ver = ""
        for line in text.splitlines():
            if "A2N20 BL616 Firmware" in line:
                ver = "  (" + ANSI_RE.sub("", line).strip() + ")"
                break
        return "A2N20 firmware (ours)" + ver, "a2n20"
    if "tangnano20k" in low:
        return "stock Tang Nano 20K firmware (Gowin/Sipeed) — prompt 'TangNano20K />'", "other"
    return "responded, but NOT A2N20 (unrecognized firmware)", "other"


def probe_cli(args):
    """Probe the device's serial port(s) to see which firmware is running."""
    if args.port:
        candidates = [args.port]
    else:
        candidates = [p.device for p in find_ports(vid=FTDI_VID)]

    if not candidates:
        print(yellow("No FTDI serial ports found."))
        print()
        print("  This is expected if the board is in boot mode, or is running")
        print("  the USB-HOST firmware (it's a USB host, not a serial device).")
        print("  If you know the port, pass it explicitly: --port /dev/cu.XXXX")
        sys.exit(2)

    print(bold("Probing serial port(s) with Ctrl-X Ctrl-C Enter break-in..."))
    print()
    found_a2n20 = False
    saw_cli = False
    for port in candidates:
        print(bold(f"Port: {port}"))
        raw, err = probe_cli_port(port, verbose=args.verbose)
        if err:
            print(f"  {yellow('skip')}: {err}")
            print()
            continue
        label, kind = identify_cli(raw)
        found_a2n20 = found_a2n20 or (kind == "a2n20")
        saw_cli = saw_cli or (kind in ("a2n20", "other"))
        color = green if kind == "a2n20" else yellow
        print(f"  {color('->')} {label}")
        if kind in ("a2n20", "other"):
            clean = ANSI_RE.sub("", raw.decode("latin-1", "replace"))
            print("  --- response ---")
            for line in clean.replace("\r", "").splitlines():
                if line.strip():
                    print(f"  | {line.strip()}")
            print("  ----------------")
        elif kind == "jtag" and args.verbose:
            print(f"  ({len(raw)} bytes, e.g. {raw[:12].hex()})")
        print()

    if found_a2n20:
        print(green("A2N20 firmware is running and reachable over serial."))
        sys.exit(0)
    if saw_cli:
        print(yellow("A CLI responded, but it is NOT the A2N20 firmware "
                     "(likely the stock/Gowin firmware)."))
        sys.exit(1)
    print(yellow("No A2N20 CLI found. Only a JTAG/MPSSE channel or silence — "
                 "the board may be running the stock or host-mode firmware."))
    sys.exit(1)


# --- Main flow helpers ---

def print_banner():
    print()
    print(bold("A2N20 BL616 Firmware Programmer"))
    print("=" * 40)
    print()


def prompt_boot_mode(step_num):
    print(bold(f"Step {step_num}: Enter boot mode"))
    print("  1. Disconnect the Tang Nano 20K from USB")
    print("  2. Press and hold the UPDATE button (top of board, behind HDMI)")
    print("  3. While holding UPDATE, connect USB-C to the Debug port")
    print("  4. Release the UPDATE button")
    prompt("\nPress Enter when ready...")
    print()


def prompt_power_cycle():
    print()
    print("  1. Disconnect USB")
    print("  2. Reconnect USB (without holding UPDATE)")
    prompt("\nPress Enter when ready...")
    print()


def enter_boot_mode(args, step_num):
    """Guide user into boot mode and return detected port."""
    if args.port:
        port = wait_for_boot_port(specified_port=args.port)
    else:
        # Check if already in boot mode
        port = detect_boot_port()
        if port:
            print(f"  BL616 already in boot mode: {bold(port)}")
            print()
            return port

        prompt_boot_mode(step_num)
        print("Detecting BL616 in boot mode...", end=" ", flush=True)
        time.sleep(1)
        port = wait_for_boot_port()
        if port:
            print(f"Found: {bold(port)}")
            print()

    if not port:
        sys.exit(1)

    return port


def check_file_exists(path, label, build_hint=None, download_url=None):
    """Check that a file exists, exit with helpful message if not."""
    if not os.path.isfile(path):
        print(red("ERROR:") + f" {label} not found: {path}")
        if build_hint:
            print(f"  {build_hint}")
        if download_url:
            print(f"  Download from: {download_url}")
            print(f"  Place in: {os.path.dirname(path)}/")
        sys.exit(1)


def verify_firmware(step_num, skip_verify=False):
    """Prompt for power cycle and verify firmware is running.

    Returns (state, ports) of detected board.
    """
    if skip_verify:
        print()
        return STATE_NOT_FOUND, []

    print()
    print(bold(f"Step {step_num}: Verify"))
    prompt_power_cycle()

    print("Waiting for USB device...", end=" ", flush=True)
    state, ports = wait_for_board_state(
        [STATE_A2N20, STATE_SIPEED_STOCK, STATE_FRIEND_20K,
         STATE_UNKNOWN_FTDI, STATE_CDC_DEMO],
        timeout_secs=10,
    )

    if state == STATE_A2N20:
        print(green("[OK]") + " A2N20 firmware is running")
        for p in ports:
            print(f"    {p.description}: {p.device}")
    elif state in (STATE_SIPEED_STOCK, STATE_FRIEND_20K, STATE_UNKNOWN_FTDI):
        # FT2232 detected but not our firmware — Stage 1 is running,
        # Stage 2 may not have loaded
        print(yellow("[PARTIAL]") + f" FT2232 device detected ({ports[0].description})")
        print("  Stage 1 is running but A2N20 firmware not detected as product name.")
        print("  This may be normal if Stage 1 hasn't chain-loaded Stage 2 yet.")
    elif state == STATE_CDC_DEMO:
        print(yellow("[WARN]") + " Bouffalo CDC DEMO detected — firmware not running")
    else:
        print(yellow("[WARN]") + " No USB device detected")
        print("  Try disconnecting and reconnecting USB.")

    print()
    return state, ports


# --- Flash strategies ---

def strategy_standalone(args, fw_path, step_num):
    """Flash firmware at 0x0 (unfused board, replaces whatever is there)."""
    port = enter_boot_mode(args, step_num)
    step_num += 1

    print(bold(f"Step {step_num}: Flashing firmware at 0x0..."))
    flash_image(port, fw_path, ADDR_STAGE1, args.baudrate,
                "Firmware", verbose=args.verbose)
    return step_num + 1


def strategy_stage2(args, fw_path, step_num):
    """Flash firmware at 0x40000 (fused board, keep existing Stage 1)."""
    port = enter_boot_mode(args, step_num)
    step_num += 1

    print(bold(f"Step {step_num}: Flashing firmware at 0x40000..."))
    flash_image(port, fw_path, ADDR_STAGE2, args.baudrate,
                "Firmware (Stage 2)", verbose=args.verbose)
    return step_num + 1


def strategy_recovery_and_stage2(args, fw_path, stage1_path, step_num):
    """Flash signed Stage 1 at 0x0 + firmware at 0x40000 (bricked fused board)."""
    port = enter_boot_mode(args, step_num)
    step_num += 1

    print(bold(f"Step {step_num}: Flashing signed Stage 1 at 0x0..."))
    flash_image(port, stage1_path, ADDR_STAGE1, args.baudrate,
                "Signed Stage 1", verbose=args.verbose)
    print()
    step_num += 1

    print(bold(f"Step {step_num}: Flashing firmware at 0x40000..."))
    flash_image(port, fw_path, ADDR_STAGE2, args.baudrate,
                "Firmware (Stage 2)", verbose=args.verbose)
    return step_num + 1


# --- Main modes ---

def run_auto(args):
    """Auto-detect board state and choose optimal flash strategy."""
    fw_path = args.firmware
    check_file_exists(fw_path, "Firmware",
                      build_hint="Build with: cd firmware && make CHIP=bl616 BOARD=bl616dk")

    # Step 1: Pre-detect board state
    print(bold("Step 1: Detecting board"))
    print("  Make sure the Tang Nano 20K is connected via USB normally")
    print("  (without holding the UPDATE button).")
    prompt("\nPress Enter when ready...")
    print()

    print("Scanning USB devices...", end=" ", flush=True)
    time.sleep(1)
    state, ports = detect_board_state()
    print()
    print_board_info(state, ports)
    print()

    if state == STATE_SIPEED_STOCK:
        # Fused board with working Stage 1 — just flash Stage 2
        print("  Strategy: Flash firmware at 0x40000 (keep Sipeed Stage 1)")
        print()
        next_step = strategy_stage2(args, fw_path, step_num=2)
        verify_firmware(next_step, args.skip_verify)
        print(green("Programming complete!"))
        print()

    elif state == STATE_FRIEND_20K:
        # Unfused board with friend_20k — replace with our firmware at 0x0
        print("  Strategy: Flash firmware at 0x0 (replace friend_20k)")
        print()
        next_step = strategy_standalone(args, fw_path, step_num=2)
        verify_firmware(next_step, args.skip_verify)
        print(green("Programming complete!"))
        print()

    elif state == STATE_A2N20:
        # Already running our firmware — update it
        # Try standalone first, fall back to stage 2 if fused
        print("  Strategy: Update firmware at 0x0")
        print()
        next_step = strategy_standalone(args, fw_path, step_num=2)

        if not args.skip_verify:
            vstate, _ = verify_firmware(next_step, skip_verify=False)
            if vstate == STATE_CDC_DEMO:
                # Fused board — our firmware at 0x0 was rejected
                print("  Fused board detected — switching to Stage 2 strategy.")
                print()
                sipeed_path = recovery_path(SIPEED_STOCK_BIN)
                check_file_exists(sipeed_path, "Signed Stage 1",
                                  download_url="https://api.dl.sipeed.com/TANG/Debugger/"
                                  "onboard/BL616/2025030317/bl616_fpga_partner_20kNano.bin")
                next_step2 = strategy_recovery_and_stage2(
                    args, fw_path, sipeed_path, step_num=next_step + 1)
                verify_firmware(next_step2, skip_verify=False)

            print(green("Programming complete!"))
            print()
        else:
            print(green("Programming complete!"))
            print()

    elif state == STATE_CDC_DEMO:
        # Bricked — need signed Stage 1 + firmware
        print("  Strategy: Flash signed Stage 1 at 0x0 + firmware at 0x40000")
        print()
        sipeed_path = recovery_path(SIPEED_STOCK_BIN)
        check_file_exists(sipeed_path, "Signed Stage 1",
                          download_url="https://api.dl.sipeed.com/TANG/Debugger/"
                          "onboard/BL616/2025030317/bl616_fpga_partner_20kNano.bin")
        next_step = strategy_recovery_and_stage2(
            args, fw_path, sipeed_path, step_num=2)
        verify_firmware(next_step, args.skip_verify)
        print(green("Programming complete!"))
        print()

    elif state == STATE_UNKNOWN_FTDI:
        # Unknown FT2232 — try standalone, fall back if needed
        print("  Strategy: Try firmware at 0x0 (unknown board, will auto-detect)")
        print()
        next_step = strategy_standalone(args, fw_path, step_num=2)

        if not args.skip_verify:
            vstate, _ = verify_firmware(next_step, skip_verify=False)
            if vstate == STATE_CDC_DEMO:
                print("  Fused board detected — switching to Stage 2 strategy.")
                print()
                sipeed_path = recovery_path(SIPEED_STOCK_BIN)
                check_file_exists(sipeed_path, "Signed Stage 1",
                                  download_url="https://api.dl.sipeed.com/TANG/Debugger/"
                                  "onboard/BL616/2025030317/bl616_fpga_partner_20kNano.bin")
                next_step2 = strategy_recovery_and_stage2(
                    args, fw_path, sipeed_path, step_num=next_step + 1)
                verify_firmware(next_step2, skip_verify=False)

            print(green("Programming complete!"))
            print()
        else:
            print(green("Programming complete!"))
            print()

    else:
        # Nothing detected
        print("  No board detected. Trying firmware at 0x0...")
        print()
        next_step = strategy_standalone(args, fw_path, step_num=2)

        if not args.skip_verify:
            vstate, _ = verify_firmware(next_step, skip_verify=False)
            if vstate == STATE_CDC_DEMO:
                print("  Fused board detected — switching to Stage 2 strategy.")
                print()
                sipeed_path = recovery_path(SIPEED_STOCK_BIN)
                check_file_exists(sipeed_path, "Signed Stage 1",
                                  download_url="https://api.dl.sipeed.com/TANG/Debugger/"
                                  "onboard/BL616/2025030317/bl616_fpga_partner_20kNano.bin")
                next_step2 = strategy_recovery_and_stage2(
                    args, fw_path, sipeed_path, step_num=next_step + 1)
                verify_firmware(next_step2, skip_verify=False)

            print(green("Programming complete!"))
            print()
        else:
            print(green("Programming complete!"))
            print()


def run_verify_only(args):
    """Verify-only: read the flashed region back and compare to --firmware,
    without writing anything. Requires the board in boot mode."""
    fw = args.firmware
    check_file_exists(fw, "Firmware",
                      build_hint="Build the firmware first, or pass --firmware PATH")
    addr = int(args.addr, 0) if args.addr else int(ADDR_STAGE2, 0)

    print(f"Mode: Verify-only — read-back compare of "
          f"{os.path.basename(fw)} at 0x{addr:x} (no writing)")
    print()

    port = enter_boot_mode(args, 1)
    print()
    ok = verify_flash_image(port, fw, addr, args.baudrate, verbose=args.verbose)
    sys.exit(0 if ok else 1)


def run_manual(args):
    """Manual mode: flash user-specified images at explicit addresses."""
    stage1_path = args.stage1
    stage2_path = args.stage2

    # Resolve default paths for flags without explicit PATH.
    # --stage2 defaults to our firmware. --stage1 must NEVER default to our
    # firmware (0x0 belongs to a Stage 1 loader); instead it auto-selects
    # the correct recovery image for the board's eFuse state, probed from
    # the BootROM once the board is in boot mode (resolved below).
    if stage2_path == "__default__":
        stage2_path = args.firmware

    # Validate files exist (auto-selected Stage 1 is validated after probing)
    if stage1_path and stage1_path != "__default__":
        check_file_exists(stage1_path, "Stage 1 image")
    if stage2_path:
        check_file_exists(stage2_path, "Stage 2 image")

    step_num = 1

    # Enter boot mode
    port = enter_boot_mode(args, step_num)
    step_num += 1

    # Auto-select the Stage 1 image from the board's eFuse state
    if stage1_path == "__default__":
        print(bold(f"Step {step_num}: Probing eFuse state for Stage 1 selection"))
        info = read_boot_info(port)
        print("  " + describe_efuse_state(info))
        stage1_path, why = pick_stage1_image(info)
        if not stage1_path:
            print(red("ERROR:") + f" {why}")
            print("  Pass an explicit image: --stage1 PATH")
            sys.exit(1)
        print(f"  Selected: {os.path.basename(stage1_path)}")
        print(f"    ({why})")
        check_file_exists(stage1_path, "Stage 1 image")
        print()
        step_num += 1

    # Flash Stage 1
    if stage1_path:
        print(bold(f"Step {step_num}: Flashing at 0x0..."))
        flash_image(port, stage1_path, ADDR_STAGE1, args.baudrate,
                    "Stage 1", verbose=args.verbose)
        print()
        step_num += 1

    # Flash Stage 2
    if stage2_path:
        print(bold(f"Step {step_num}: Flashing at 0x40000..."))
        flash_image(port, stage2_path, ADDR_STAGE2, args.baudrate,
                    "Stage 2", verbose=args.verbose)
        step_num += 1

    # Verify
    verify_firmware(step_num, args.skip_verify)
    print(green("Programming complete!"))
    print()


# --- Entry point ---

def main():
    parser = argparse.ArgumentParser(
        description="A2N20 BL616 Firmware Programmer",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""\
modes:
  (default)        Auto-detect board state and flash accordingly (recommended)
  --detect         Detect board state and exit (no flashing)
  --stage1 [PATH]  Flash image at 0x0 (default: auto-select the correct
                   recovery Stage 1 for the board's eFuse state — Sipeed
                   partner image for fused boards, friend_20k for unfused)
  --stage2 [PATH]  Flash image at 0x40000 (default: firmware binary)

auto-detect identifies the board by USB product string:
  "USB Debugger"   → Sipeed stock (fused) → flash at 0x40000 only
  "20K's FRIEND"   → friend_20k (unfused) → flash at 0x0
  "JTAG Debugger"  → A2N20 firmware       → update at 0x0, fallback to 0x40000
  CDC DEMO         → bricked              → flash signed Stage 1 + firmware

examples:
  %(prog)s                              # auto-detect (recommended)
  %(prog)s --detect                     # just show board status
  %(prog)s --stage2                     # force firmware at 0x40000
  %(prog)s --stage1                     # restore the right Stage 1 (auto)
  %(prog)s --stage1 recovery/friend_20k_bl616.bin  # flash a specific Stage 1
  %(prog)s --stage1 sipeed.bin --stage2 # flash custom Stage 1 + firmware
""",
    )

    parser.add_argument("--detect", action="store_true",
                        help="Detect board state and exit (no flashing)")
    parser.add_argument("--stage1", nargs="?", const="__default__", default=None,
                        metavar="PATH",
                        help="Flash image at 0x0 (default: auto-select recovery Stage 1 by eFuse state)")
    parser.add_argument("--stage2", nargs="?", const="__default__", default=None,
                        metavar="PATH",
                        help="Flash image at 0x40000 (default: firmware binary)")

    parser.add_argument("--port", metavar="PORT",
                        help="Serial port (auto-detect if omitted)")
    parser.add_argument("--firmware", metavar="PATH",
                        default=default_firmware_path(),
                        help="A2N20 firmware binary (default: firmware/build/build_out/"
                             "a2n20_bl616_bl616.bin)")
    parser.add_argument("--baudrate", metavar="BAUD", type=int,
                        default=DEFAULT_BAUDRATE,
                        help=f"Flash baudrate (default: {DEFAULT_BAUDRATE})")
    parser.add_argument("--verbose", action="store_true",
                        help="Show bflb-iot-tool output")
    parser.add_argument("--skip-verify", action="store_true",
                        help="Skip post-flash verification")
    parser.add_argument("--non-interactive", "--yes", "-y", action="store_true",
                        dest="non_interactive",
                        help="Never prompt; assume the board is already in boot "
                             "mode. For scripts/agents. Pair with --port. "
                             "Implies --skip-verify (verify needs a power-cycle).")
    parser.add_argument("--verify-flash", action="store_true", dest="verify_flash",
                        help="After each successful write, read the region back "
                             "from the chip and byte-compare it to the image. "
                             "No power-cycle needed (unlike the default verify).")
    parser.add_argument("--probe-cli", action="store_true", dest="probe_cli",
                        help="Identify the running firmware: open the device's "
                             "serial port(s), send the Ctrl-X Ctrl-C Enter "
                             "break-in + 'help', and report what answers. No "
                             "flashing.")
    parser.add_argument("--addr", metavar="ADDR",
                        help="Flash address for standalone --verify-flash "
                             "(default 0x40000 = Stage 2). Needs boot mode.")

    args = parser.parse_args()

    # Non-interactive use can't perform the physical power-cycle that
    # verify_firmware() waits on, so skip it automatically.
    global NON_INTERACTIVE, VERIFY_FLASH
    NON_INTERACTIVE = args.non_interactive
    VERIFY_FLASH = args.verify_flash
    if args.non_interactive:
        args.skip_verify = True

    print_banner()

    # --detect mode: just scan and report, no flashing
    if args.detect:
        print("Scanning USB devices...")
        print()
        state, ports = detect_board_state()
        print_board_info(state, ports)
        print()
        sys.exit(0)

    # --probe-cli mode: talk to the serial CLI to see which firmware is live
    if args.probe_cli:
        probe_cli(args)
        return  # probe_cli() exits

    # Check dependencies
    check_bflb_iot_tool()

    manual_mode = args.stage1 is not None or args.stage2 is not None

    # --verify-flash with no stage flags = verify-only (read back & compare,
    # no writing). Combined with --stage1/--stage2 it instead verifies each
    # write (handled inside flash_image via VERIFY_FLASH).
    if args.verify_flash and not manual_mode:
        run_verify_only(args)
        return  # exits

    if manual_mode:
        # Describe manual mode
        parts = []
        if args.stage1 is not None:
            name = os.path.basename(args.stage1) if args.stage1 != "__default__" else "firmware"
            parts.append(f"{name} at 0x0")
        if args.stage2 is not None:
            name = os.path.basename(args.stage2) if args.stage2 != "__default__" else "firmware"
            parts.append(f"{name} at 0x40000")
        print(f"Mode: Manual — flash {' + '.join(parts)}")
        print()
        run_manual(args)
    else:
        print("Mode: Auto-detect")
        print()
        run_auto(args)


if __name__ == "__main__":
    main()
